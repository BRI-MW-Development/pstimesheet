# ── Live (ERP-Live) database ─────────────────────────────────────────────────
DB_SERVER=
DB_NAME=ERP-Live
DB_USER=
DB_PASSWORD=
DB_PORT=1433
DB_TRUST_CERT=yes

# ── Dev / timesheet database ─────────────────────────────────────────────────
DEV_DB_SERVER=
DEV_DB_NAME=ERP-Dev
DEV_DB_USER=
DEV_DB_PASSWORD=
DEV_DB_PORT=1433
DEV_DB_TRUST_CERT=yes

# ── Application ──────────────────────────────────────────────────────────────
PORT=3000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to the URL users will open in their browser (the server's LAN IP + port).
# In production the frontend is served from the same origin as the API, so
# CORS only matters for developer machines running Vite (port 5173).
# Example: FRONTEND_ORIGIN=http://192.168.1.100:3000
FRONTEND_ORIGIN=

# Optional: comma-separated extra origins (dev machines / other LAN hosts).
# Example: EXTRA_ORIGINS=http://192.168.1.50:5173,http://192.168.1.51:3000
EXTRA_ORIGINS=
